import logging
from config import LOG_FILE

logging.basicConfig(
    filename=LOG_FILE,
    level=logging.INFO,
    format="%(asctime)s | %(levelname)s | %(message)s"
)

def info(message):
    logging.info(message)
    print("[INFO]", message)

def warning(message):
    logging.warning(message)
    print("[WARNING]", message)

def error(message):
    logging.error(message)
    print("[ERROR]", message)
